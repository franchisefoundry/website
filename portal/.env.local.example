# Supabase — get these from your project's API settings
# https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this client-side
# Used only in server-side API routes for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — for sending invite/notification emails
# https://resend.com → API Keys
RESEND_API_KEY=re_your-key-here

# The URL this portal is deployed at (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Dev role-switcher — only active in NODE_ENV=development
# Set these to your dummy test account credentials
# The floating ⚡ Dev panel uses these for one-click role switching
NEXT_PUBLIC_DEV_ADMIN_EMAIL=admin@test.franchisefoundry.com
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=your-test-password
NEXT_PUBLIC_DEV_FRANCHISEE_EMAIL=franchisee@test.franchisefoundry.com
NEXT_PUBLIC_DEV_FRANCHISEE_PASSWORD=your-test-password
NEXT_PUBLIC_DEV_FRANCHISOR_EMAIL=franchisor@test.franchisefoundry.com
NEXT_PUBLIC_DEV_FRANCHISOR_PASSWORD=your-test-password
